{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:soleil:contracts:task-run-state:v1",
  "title": "TaskRunState v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract",
    "version",
    "run_id",
    "context_id",
    "plugin_id",
    "route_id",
    "state",
    "state_history",
    "created_at",
    "updated_at",
    "plan",
    "artifacts",
    "qa",
    "failure"
  ],
  "properties": {
    "contract": {"const": "TaskRunState"},
    "version": {"const": 1},
    "run_id": {"type": "string", "minLength": 8},
    "context_id": {"type": "string", "minLength": 8},
    "plugin_id": {"type": "string", "minLength": 1},
    "route_id": {"type": "string", "minLength": 1},
    "state": {"$ref": "#/$defs/state"},
    "state_history": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["state", "at", "actor"],
        "properties": {
          "state": {"$ref": "#/$defs/state"},
          "at": {"type": "string", "format": "date-time"},
          "actor": {"enum": ["user", "site", "plugin", "bridge"]},
          "reason": {"type": "string"}
        }
      }
    },
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "plan": {"type": ["object", "null"]},
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_id", "artifact_type", "status"],
        "properties": {
          "artifact_id": {"type": "string", "minLength": 1},
          "artifact_type": {"type": "string", "minLength": 1},
          "opaque_local_ref": {"type": "string", "minLength": 1},
          "status": {"enum": ["created", "qa_passed", "failed"]}
        }
      }
    },
    "qa": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["passed", "checks"],
          "properties": {
            "passed": {"type": "boolean"},
            "checks": {"type": "array", "items": {"type": "object"}}
          }
        }
      ]
    },
    "failure": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["code", "message", "retryable"],
          "properties": {
            "code": {"type": "string", "minLength": 1},
            "message": {"type": "string", "minLength": 1},
            "retryable": {"type": "boolean"}
          }
        }
      ]
    }
  },
  "$defs": {
    "state": {
      "enum": [
        "source_ready",
        "route_or_brief_locked",
        "permissions_confirmed",
        "plan_approved",
        "running",
        "qa_passed",
        "failed"
      ]
    }
  }
}
