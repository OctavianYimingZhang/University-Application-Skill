{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:soleil:contracts:local-bridge-protocol:v1",
  "title": "LocalBridgeProtocol v1",
  "description": "Handshake and authenticated request envelopes for a strict loopback-only bridge.",
  "oneOf": [
    {"$ref": "#/$defs/helloRequest"},
    {"$ref": "#/$defs/helloResponse"},
    {"$ref": "#/$defs/authenticatedRequest"}
  ],
  "$defs": {
    "helloRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract", "version", "message_type", "origin", "client_nonce"],
      "properties": {
        "contract": {"const": "LocalBridgeProtocol"},
        "version": {"const": 1},
        "message_type": {"const": "hello_request"},
        "origin": {"type": "string", "format": "uri"},
        "client_nonce": {"type": "string", "minLength": 16}
      }
    },
    "helloResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract", "version", "message_type", "session_token", "expires_at", "allowed_origins", "loopback_only", "rate_limit", "plugin_versions"],
      "properties": {
        "contract": {"const": "LocalBridgeProtocol"},
        "version": {"const": 1},
        "message_type": {"const": "hello_response"},
        "session_token": {"type": "string", "minLength": 43, "writeOnly": true},
        "expires_at": {"type": "string", "format": "date-time"},
        "allowed_origins": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "format": "uri"}},
        "loopback_only": {"const": true},
        "rate_limit": {
          "type": "object",
          "additionalProperties": false,
          "required": ["requests", "window_seconds"],
          "properties": {
            "requests": {"type": "integer", "minimum": 1},
            "window_seconds": {"type": "integer", "minimum": 1}
          }
        },
        "plugin_versions": {"type": "object", "additionalProperties": {"type": "string"}},
        "test_runtime": {"type": "boolean", "description": "True only when the bridge uses explicit, disjoint test memory and execution roots under the operating-system temporary directory."}
      }
    },
    "authenticatedRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract", "version", "message_type", "session_token", "origin", "transfer_consent", "request_id", "payload"],
      "properties": {
        "contract": {"const": "LocalBridgeProtocol"},
        "version": {"const": 1},
        "message_type": {"enum": ["source_transfer", "plan", "run", "status", "artifact"]},
        "session_token": {"type": "string", "minLength": 43, "writeOnly": true},
        "origin": {"type": "string", "format": "uri"},
        "transfer_consent": {"const": true},
        "request_id": {"type": "string", "minLength": 8},
        "payload": {"type": "object"}
      }
    }
  }
}
