{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:soleil:contracts:academic-task-context:v1",
  "title": "AcademicTaskContext v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract",
    "version",
    "context_id",
    "created_at",
    "original_prompt",
    "route_selection",
    "course_or_case",
    "source_references",
    "relevant_memory",
    "permissions",
    "decisions"
  ],
  "properties": {
    "contract": {"const": "AcademicTaskContext"},
    "version": {"const": 1},
    "context_id": {"type": "string", "minLength": 8},
    "created_at": {"type": "string", "format": "date-time"},
    "original_prompt": {"type": "string", "minLength": 1},
    "route_selection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["route_id", "status"],
      "properties": {
        "route_id": {"type": "string", "minLength": 1},
        "status": {"enum": ["suggested", "explicitly_confirmed"]}
      }
    },
    "course_or_case": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "stable_id", "label"],
          "properties": {
            "kind": {"enum": ["course", "application_case"]},
            "stable_id": {"type": "string", "minLength": 1},
            "label": {"type": "string", "minLength": 1}
          }
        }
      ]
    },
    "source_references": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_id", "trust_status"],
        "properties": {
          "source_id": {"type": "string", "minLength": 1},
          "checksum_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "locator_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "trust_status": {"enum": ["unreviewed", "trusted", "rejected"]}
        }
      }
    },
    "relevant_memory": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["store", "record_ids", "purpose"],
        "properties": {
          "store": {"type": "string", "minLength": 1},
          "record_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "purpose": {"type": "string", "minLength": 1}
        }
      }
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["permission_id", "scope", "status"],
        "properties": {
          "permission_id": {"type": "string", "minLength": 1},
          "scope": {"type": "string", "minLength": 1},
          "status": {"enum": ["not_requested", "denied", "explicitly_confirmed"]},
          "confirmed_at": {"type": ["string", "null"], "format": "date-time"}
        }
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["decision_id", "value", "status"],
        "properties": {
          "decision_id": {"type": "string", "minLength": 1},
          "value": {},
          "status": {"enum": ["suggested", "explicitly_confirmed"]},
          "confirmed_at": {"type": ["string", "null"], "format": "date-time"}
        }
      }
    },
    "requested_output_language": {"type": "string", "default": "en"},
    "metadata": {"type": "object"}
  }
}
