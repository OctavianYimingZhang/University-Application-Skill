{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Study Abroad Advisor Ontology Data",
  "type": "object",
  "properties": {
    "workbook_title": { "type": "string" },
    "generated_on": { "type": "string" },
    "ontology": {
      "type": "object",
      "properties": {
        "applicants": { "type": "array", "items": { "type": "object" } },
        "education_credentials": { "type": "array", "items": { "type": "object" } },
        "institutions": { "type": "array", "items": { "type": "object" } },
        "programs": { "type": "array", "items": { "type": "object" } },
        "application_cases": { "type": "array", "items": { "type": "object" } },
        "requirement_rules": { "type": "array", "items": { "type": "object" } },
        "document_artifacts": { "type": "array", "items": { "type": "object" } },
        "source_evidence": { "type": "array", "items": { "type": "object" } },
        "tasks": { "type": "array", "items": { "type": "object" } },
        "risk_flags": { "type": "array", "items": { "type": "object" } },
        "deadlines": { "type": "array", "items": { "type": "object" } },
        "offer_decisions": { "type": "array", "items": { "type": "object" } },
        "visa_immigration_cases": { "type": "array", "items": { "type": "object" } },
        "links": { "type": "array", "items": { "type": "object" } }
      },
      "additionalProperties": true
    }
  },
  "required": ["ontology"],
  "additionalProperties": true
}
