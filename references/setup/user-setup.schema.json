{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UserSetup",
  "type": "object",
  "anyOf": [
    {"required": ["workflow_mode", "output_mode"]},
    {"required": ["task_type", "output_format"]}
  ],
  "$defs": {
    "evidenceRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id", "value", "source", "evidence_date", "confirmation_status", "confirmed_at",
        "source_availability", "fact_verification", "completeness", "application_cycle", "accessed_at", "staleness"
      ],
      "properties": {
        "evidence_id": {"type": "string", "minLength": 1},
        "value": {"type": "string", "minLength": 1},
        "fact_class": {"enum": ["mutable_official_fact", "applicant_personal_fact"]},
        "evidence_use": {"enum": ["writing", "applicant_comparison", "official_requirement", "material_document", "submission"]},
        "source": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": {"enum": ["public_url", "local_document", "user_confirmation"]},
            "url": {"type": "string", "format": "uri"},
            "title": {"type": "string", "minLength": 1},
            "publisher": {"type": "string", "minLength": 1},
            "opaque_local_ref": {"type": "string", "minLength": 1},
            "confirmed_by": {"type": "string", "minLength": 1}
          },
          "anyOf": [
            {
              "required": ["url", "title", "publisher"],
              "properties": {"type": {"const": "public_url"}}
            },
            {
              "required": ["type", "opaque_local_ref", "title"],
              "properties": {"type": {"const": "local_document"}}
            },
            {
              "required": ["type", "confirmed_by", "title"],
              "properties": {"type": {"const": "user_confirmation"}}
            }
          ]
        },
        "evidence_date": {
          "oneOf": [
            {"type": "string", "format": "date"},
            {"type": "string", "format": "date-time"}
          ]
        },
        "confirmation_status": {"enum": ["unconfirmed", "explicitly_confirmed"]},
        "confirmed_at": {"type": ["string", "null"], "format": "date-time"},
        "source_availability": {"enum": ["available", "unavailable", "unknown"]},
        "fact_verification": {"enum": ["unverified", "verified", "conflicted"]},
        "completeness": {"enum": ["placeholder", "partial", "complete"]},
        "application_cycle": {"type": "string", "minLength": 1},
        "accessed_at": {
          "oneOf": [
            {"type": "string", "format": "date"},
            {"type": "string", "format": "date-time"}
          ]
        },
        "staleness": {"enum": ["fresh", "stale", "unknown"]}
      }
    }
  },
  "properties": {
    "user_setup_id": {"type": "string"},
    "applicant_id": {"type": "string"},
    "workflow_mode": {
      "type": "string",
      "enum": [
        "quick_triage",
        "full_shortlist",
        "exact_program_selection",
        "requirement_audit",
        "essay_sop",
        "application_writing_studio",
        "materials_check",
        "workbook_build",
        "programme_table_cleaning",
        "submission_readiness",
        "source_refresh",
        "visa_readiness",
        "visa_route"
      ]
    },
    "task_type": {
      "type": "string",
      "enum": ["shortlist", "requirement_check", "visa_readiness", "essay_plan", "materials_check"]
    },
    "output_mode": {
      "type": "string",
      "enum": ["brainstorm", "draft", "source_backed", "verified"]
    },
    "output_format": {"type": "string"},
    "recommendation_count": {"type": "integer", "minimum": 1},
    "preferred_depth": {"type": "string"},
    "ask_style": {
      "type": "string",
      "enum": ["compact_batches", "step_by_step", "form_like"]
    },
    "source_policy": {"type": "string"},
    "requested_output_language": {"type": "string"},
    "evidence_records": {"type": "array", "items": {"$ref": "#/$defs/evidenceRecord"}},
    "program_name": {"type": "string"},
    "program_name_or_url": {"type": "string"},
    "program_names_or_urls": {"type": "array", "items": {"type": "string"}},
    "target_programs": {"type": "array", "items": {"type": "string"}},
    "application_cycle": {"type": "string"},
    "prompt": {"type": "string"},
    "essay_prompt": {"type": "string"},
    "word_limit": {"type": ["integer", "string"]},
    "character_limit": {"type": ["integer", "string"]},
    "audience": {"type": "string"},
    "intended_use": {"type": "string"},
    "submission_use": {"type": "string"},
    "output_location": {"type": "string"},
    "output_path": {"type": "string"},
    "overwrite_existing": {"type": ["boolean", "null"]},
    "overwrite_decision": {"type": "string"},
    "applicant_background": {"type": "string"},
    "document_inventory": {"type": "array", "items": {"type": "object"}},
    "application_materials": {"type": "array", "items": {"type": "object"}},
    "documents": {"type": "array", "items": {"type": "object"}},
    "writing_revision_items": {"type": "array", "items": {"type": "object"}},
    "revision_decision_ledger": {
      "oneOf": [
        {"type": "array", "items": {"type": "object"}},
        {
          "type": "object",
          "properties": {
            "items": {"type": "array", "items": {"type": "object"}},
            "decisions": {"type": "array", "items": {"type": "object"}}
          },
          "additionalProperties": true
        }
      ]
    },
    "privacy_mode": {"type": "string"},
    "export_format": {"type": "string"},
    "ranking_weight": {"type": ["number", "string"]},
    "admission_safety_weight": {"type": ["number", "string"]},
    "budget_weight": {"type": ["number", "string"]},
    "city_weight": {"type": ["number", "string"]},
    "career_weight": {"type": ["number", "string"]},
    "research_fit_weight": {"type": ["number", "string"]},
    "visa_work_route_weight": {"type": ["number", "string"]},
    "deadline_feasibility_weight": {"type": ["number", "string"]},
    "source_workbook_dir_or_files": {
      "oneOf": [
        {"type": "string"},
        {"type": "array", "items": {"type": "string"}}
      ]
    },
    "source_workbook_dir": {"type": "string"},
    "cleaned_output_dir": {"type": "string"},
    "copy_back_requested": {"type": "boolean"},
    "can_do": {"type": "array", "items": {"type": "string"}},
    "cannot_do": {"type": "array", "items": {"type": "string"}},
    "blockers": {"type": "array", "items": {"type": "string"}},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "next_questions": {"type": "array", "items": {"type": "string"}},
    "profile": {
      "type": "object",
      "properties": {
        "target_degree_level": {"type": "string"},
        "target_intake": {"type": "string"},
        "target_countries": {"type": "array", "items": {"type": "string"}},
        "citizenship_countries": {"type": "array", "items": {"type": "string"}},
        "residence_country": {"type": "string"},
        "education_country": {"type": "string"},
        "passport_country": {"type": "string"},
        "visa_application_country": {"type": "string"},
        "target_field": {"type": "string"},
        "current_institution": {"type": "string"},
        "current_major": {"type": "string"},
        "current_qualification": {"type": "string"},
        "academic_background": {"type": "string"},
        "gpa_value": {"type": "string"},
        "gpa_scale": {"type": "string"},
        "language_status": {"type": "string"},
        "core_courses": {"type": "array", "items": {"type": "string"}},
        "budget_annual": {"type": "string"},
        "constraints": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    },
    "memory": {
      "type": "object",
      "properties": {
        "schema_version": {"type": "string"},
        "privacy_mode": {"type": "string"},
        "profile": {"type": "object", "additionalProperties": true},
        "course_memory": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
        "lecture_delta_memory": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
        "writing_voice": {"type": "object", "additionalProperties": true},
        "notes_preferences": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
        "exam_preparation_preferences": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
        "application_preferences": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
        "source_log": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
        "conflicts": {"type": "array", "items": {"type": "object", "additionalProperties": true}}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
