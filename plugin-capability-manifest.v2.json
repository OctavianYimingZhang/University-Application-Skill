{
  "contract": "PluginCapabilityManifest",
  "version": 2,
  "plugin_id": "university-application-skill",
  "plugin_version": "0.4.0",
  "default_output_language": "en",
  "supported_context_versions": [1],
  "routes": [
    {
      "route_id": "program_research",
      "owning_skill": "program-research",
      "triggers": {
        "semantic_intents": ["programme discovery", "shortlist research", "official programme comparison"],
        "examples": ["Find official masters programmes in my field", "帮我查找合适的大学项目", "Buscar programas universitarios oficiales"],
        "direct_invocation": true
      },
      "required_inputs": [
        {"input_id": "academic_task_context", "required": false, "schema_ref": "contracts/academic-task-context-v1.schema.json"},
        {"input_id": "curated_catalogue_index", "required": false, "schema_ref": "catalogues/schemas/catalogue-index-v1.schema.json", "description": "Plugin-owned programme identity index; identity listing does not verify programme requirements."},
        {"input_id": "target_scope", "required": true, "description": "Degree level, field, destination, and intake, with gaps kept explicit."}
      ],
      "gates": [
        {"gate_id": "route_confirmation", "required": true, "satisfied_by": "Direct user intent or AcademicTaskContext route_selection.status=explicitly_confirmed"},
        {"gate_id": "official_source_verification", "required": true, "satisfied_by": "Programme facts carry official provenance and separate verification states"}
      ],
      "outputs": [
        {"output_id": "curated_catalogue_index", "media_type": "application/json", "schema_ref": "catalogues/schemas/catalogue-index-v1.schema.json"},
        {"output_id": "source_backed_programme_list", "media_type": "application/json"},
        {"output_id": "application_case", "media_type": "application/json", "schema_ref": "schemas/application-case-v1.schema.json"},
        {"output_id": "source_log", "media_type": "application/json"}
      ],
      "adapter_entrypoint": {"type": "skill", "value": "skills/program-research/SKILL.md"},
      "supported_context_versions": [1]
    },
    {
      "route_id": "requirement_audit",
      "owning_skill": "requirement-audit",
      "triggers": {
        "semantic_intents": ["entry requirement audit", "language requirement check", "fee and deadline verification"],
        "examples": ["Check this programme's exact requirements", "核对这个项目的入学要求", "Verificar los requisitos de admisión"],
        "direct_invocation": true
      },
      "required_inputs": [
        {"input_id": "academic_task_context", "required": false, "schema_ref": "contracts/academic-task-context-v1.schema.json"},
        {"input_id": "programme", "required": true, "description": "Named programme or official programme URL."}
      ],
      "gates": [
        {"gate_id": "route_confirmation", "required": true, "satisfied_by": "Direct user intent or explicitly confirmed route"},
        {"gate_id": "official_source_verification", "required": true, "satisfied_by": "Each hard requirement has current official provenance"},
        {"gate_id": "applicant_evidence_confirmation", "required": true, "satisfied_by": "Applicant comparison uses only evidence records that pass references/evidence-contract.md"}
      ],
      "outputs": [
        {"output_id": "requirement_table", "media_type": "application/json"},
        {"output_id": "gap_list", "media_type": "application/json"},
        {"output_id": "source_log", "media_type": "application/json"}
      ],
      "adapter_entrypoint": {"type": "skill", "value": "skills/requirement-audit/SKILL.md"},
      "supported_context_versions": [1]
    },
    {
      "route_id": "materials_check",
      "owning_skill": "materials-check",
      "triggers": {
        "semantic_intents": ["application materials check", "document readiness", "evidence gap review"],
        "examples": ["Check whether my application documents are ready", "检查我的申请材料是否齐全", "Revisar mis documentos de solicitud"],
        "direct_invocation": true
      },
      "required_inputs": [
        {"input_id": "academic_task_context", "required": false, "schema_ref": "contracts/academic-task-context-v1.schema.json"},
        {"input_id": "programme_requirements", "required": true, "description": "Source-backed programme document requirements."}
      ],
      "gates": [
        {"gate_id": "route_confirmation", "required": true, "satisfied_by": "Direct user intent or explicitly confirmed route"},
        {"gate_id": "applicant_evidence_confirmation", "required": true, "satisfied_by": "A complete item requires an evidence record that passes references/evidence-contract.md"}
      ],
      "outputs": [
        {"output_id": "materials_checklist", "media_type": "application/json"},
        {"output_id": "blockers", "media_type": "application/json"}
      ],
      "adapter_entrypoint": {"type": "skill", "value": "skills/materials-check/SKILL.md"},
      "supported_context_versions": [1]
    },
    {
      "route_id": "application_writing_studio",
      "owning_skill": "application-writing-studio",
      "triggers": {
        "semantic_intents": ["personal statement planning", "statement of purpose", "admissions essay evidence review"],
        "examples": ["Help plan my personal statement from confirmed evidence", "帮我规划个人陈述", "Ayúdame a planificar mi carta de motivación"],
        "direct_invocation": true
      },
      "required_inputs": [
        {"input_id": "academic_task_context", "required": false, "schema_ref": "contracts/academic-task-context-v1.schema.json"},
        {"input_id": "writing_brief", "required": true, "description": "Programme, prompt, audience, word limit, and intended use."}
      ],
      "gates": [
        {"gate_id": "brief_lock", "required": true, "satisfied_by": "User confirms every plan-changing writing field"},
        {"gate_id": "applicant_evidence_confirmation", "required": true, "satisfied_by": "Narrative claims use only evidence records that pass references/evidence-contract.md"},
        {"gate_id": "planning_approval", "required": true, "satisfied_by": "User approves the visible structure and evidence map"}
      ],
      "outputs": [
        {"output_id": "writing_plan", "media_type": "application/json"},
        {"output_id": "draft_if_approved", "media_type": "text/markdown"}
      ],
      "adapter_entrypoint": {"type": "skill", "value": "skills/application-writing-studio/SKILL.md"},
      "supported_context_versions": [1]
    },
    {
      "route_id": "submission_readiness",
      "owning_skill": "submission-readiness",
      "triggers": {
        "semantic_intents": ["final submission check", "application readiness", "pre-submission blockers"],
        "examples": ["Run a final application readiness check", "提交前检查我的申请", "Comprobar la solicitud antes de enviarla"],
        "direct_invocation": true
      },
      "required_inputs": [
        {"input_id": "academic_task_context", "required": false, "schema_ref": "contracts/academic-task-context-v1.schema.json"},
        {"input_id": "application_case", "required": true, "schema_ref": "schemas/application-case-v1.schema.json", "description": "Named programme and application cycle."}
      ],
      "gates": [
        {"gate_id": "route_confirmation", "required": true, "satisfied_by": "Direct user intent or explicitly confirmed route"},
        {"gate_id": "applicant_evidence_confirmation", "required": true, "satisfied_by": "Readiness passes only with confirmed evidence records"},
        {"gate_id": "current_cycle_verification", "required": true, "satisfied_by": "Deadlines, fees, and requirements are current for the application cycle"}
      ],
      "outputs": [
        {"output_id": "readiness_checklist", "media_type": "application/json"},
        {"output_id": "blockers", "media_type": "application/json"}
      ],
      "adapter_entrypoint": {"type": "skill", "value": "skills/submission-readiness/SKILL.md"},
      "supported_context_versions": [1]
    },
    {
      "route_id": "visa_readiness",
      "owning_skill": "visa-readiness",
      "triggers": {
        "semantic_intents": ["student visa readiness", "immigration document preparation", "sponsorship or CAS preparation"],
        "examples": ["Check my student visa readiness", "检查学生签证准备情况", "Revisar la preparación para el visado de estudiante"],
        "direct_invocation": true
      },
      "required_inputs": [
        {"input_id": "academic_task_context", "required": false, "schema_ref": "contracts/academic-task-context-v1.schema.json"},
        {"input_id": "visa_route_context", "required": true, "description": "Destination, citizenship, application location, intake, and funding basis."}
      ],
      "gates": [
        {"gate_id": "route_confirmation", "required": true, "satisfied_by": "Direct user intent or explicitly confirmed route"},
        {"gate_id": "official_government_provenance", "required": true, "satisfied_by": "Legal and procedural claims use current official government or immigration-authority sources"},
        {"gate_id": "applicant_evidence_confirmation", "required": true, "satisfied_by": "Funding and document readiness use only evidence records that pass references/evidence-contract.md"},
        {"gate_id": "non_legal_advice_boundary", "required": true, "satisfied_by": "Output is administrative readiness information and includes no legal interpretation or outcome guarantee"}
      ],
      "outputs": [
        {"output_id": "visa_readiness_notes", "media_type": "application/json"},
        {"output_id": "document_gaps", "media_type": "application/json"},
        {"output_id": "source_log", "media_type": "application/json"}
      ],
      "adapter_entrypoint": {"type": "skill", "value": "skills/visa-readiness/SKILL.md"},
      "supported_context_versions": [1]
    },
    {
      "route_id": "programme_table_cleaning",
      "owning_skill": "programme-table-cleaning",
      "triggers": {
        "semantic_intents": ["programme catalogue maintenance", "programme workbook normalization", "official table refresh"],
        "examples": ["Clean this official programme workbook", "维护并清理项目目录表", "Normalizar esta tabla oficial de programas"],
        "direct_invocation": true
      },
      "required_inputs": [
        {"input_id": "academic_task_context", "required": false, "schema_ref": "contracts/academic-task-context-v1.schema.json"},
        {"input_id": "source_workbooks", "required": true, "description": "Explicitly supplied programme workbooks or tables."}
      ],
      "gates": [
        {"gate_id": "maintenance_authorization", "required": true, "satisfied_by": "User explicitly requests catalogue or workbook maintenance"},
        {"gate_id": "lineage_preservation", "required": true, "satisfied_by": "Raw values, source URLs, cycles, and access dates remain traceable"}
      ],
      "outputs": [
        {"output_id": "cleaned_programme_workbook", "media_type": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"},
        {"output_id": "programme_identity_catalogue", "media_type": "application/json", "schema_ref": "catalogues/schemas/institution-catalogue-v1.schema.json"},
        {"output_id": "verification_report", "media_type": "application/json"}
      ],
      "adapter_entrypoint": {"type": "skill", "value": "skills/programme-table-cleaning/SKILL.md"},
      "supported_context_versions": [1]
    }
  ]
}
