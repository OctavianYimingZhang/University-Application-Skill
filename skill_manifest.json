{
  "schema_version": 3,
  "skill_id": "university-application-index",
  "repo": "OctavianYimingZhang/University-Application-Skill",
  "branch": "main",
  "entrypoint": "SKILL.md",
  "multi_skill_system": true,
  "plugin_router_skill": {
    "name": "university-application-index",
    "path": "skills/university-application-index/SKILL.md",
